# 複製此檔案為 .env 並填入你的設定
# cp .env.example .env

# ── Twitch API ──────────────────────────────
# 至 https://dev.twitch.tv/console 申請
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# ── 追蹤實況主（逗號分隔，不含空格）─────────
TWITCH_STREAMERS=shroud,ninja,pokelawls

# ── 錄影設定 ────────────────────────────────
# 畫質：best / 1080p60 / 1080p / 720p60 / 720p / 480p / 360p / worst
QUALITY=best

# 檢查開台間隔（秒）
CHECK_INTERVAL=60
